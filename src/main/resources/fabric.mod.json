{
	"schemaVersion": 1,
	"id": "cronis",
	"version": "${version}",
	"name": "Cronis",
	"description": "A clean, modern and highly customizable HUD framework for Hypixel SkyBlock.",
	"authors": [
		"Cronis Team"
	],
	"contact": {
		"homepage": "https://github.com/Urban512/Cronis",
		"sources": "https://github.com/Urban512/Cronis"
	},
	"license": "MIT",
	"icon": "assets/cronis/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"dev.cronis.Cronis"
		],
		"client": [
			"dev.cronis.client.CronisClient"
		]
	},
	"mixins": [
		"cronis.mixins.json",
		{
			"config": "cronis.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "~26.1.2",
		"java": ">=25",
		"fabric-api": "*"
	}
}